{
  "name": "client-debug-log-shared",
  "version": "1.1.0",
  "description": "Shared enums and TypeScript types for client-debug-log and client-debug-log-client",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mats-hanisch/client-debug-log-shared.git"
  }
}
